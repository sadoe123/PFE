APP_NAME=OnePilot
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

METADATA_DB_HOST=onepilot_postgres
METADATA_DB_PORT=5432
METADATA_DB_NAME=onepilot_dev
METADATA_DB_USER=onepilot
METADATA_DB_PASSWORD=onepilot_secret

POSTGRES_USER=onepilot
POSTGRES_PASSWORD=onepilot_secret
POSTGRES_DB=onepilot_dev

MYSQL_USER=onepilot
MYSQL_PASSWORD=onepilot_secret
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DB=onepilot_dev

REDIS_HOST=onepilot_redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

SECRET_KEY=your-secret-key-minimum-32-characters-change-this
JWT_SECRET_KEY=your-jwt-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

LOG_LEVEL=INFO
LOG_FILE=data/logs/onepilot.log

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

TEST_POSTGRES_URL=postgresql://onepilot:onepilot_secret@localhost:5433/onepilot_dev
TEST_MYSQL_URL=mysql+pymysql://onepilot:onepilot_secret@localhost:3306/onepilot_dev

ENABLE_VOICE=true
ENABLE_DASHBOARDS=true
ENABLE_RAG=true

OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:7b

MEILI_MASTER_KEY=onepilot_meili_key
MEILI_HOST=http://onepilot_meilisearch:7700

PIPER_VOICES_DIR=/app/models/piper
PIPER_DEFAULT_VOICE=fr_FR-upmc-medium
VOSK_MODEL_PATH=/app/models/vosk/vosk-model-small-fr-0.22
WHISPER_MODEL=small
WHISPER_LANG=fr

HF_HOME=/app/models/hf
TRANSFORMERS_CACHE=/app/models/hf
SENTENCE_TRANSFORMERS_HOME=/app/models/hf